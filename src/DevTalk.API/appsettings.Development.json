{
  "serilog": {
    "Using": [
      "Serilog.Sinks.ApplicationInsights",
      "Serilog.Sinks.Elasticsearch"
    ],
    "MinimumLevel": {
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd-MM HH:mm:ss} {Level:u3}] |{SourceContext}| {NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/devtalk-API-.json",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "devtalk-api-{0:yyyy.MM.dd}",
          "autoRegisterTemplate": true
        }
      }
    ]
  },
  "ConnectionStrings": {
    "cs": "Host=postgres;Port=5432;Database=DevTalkDb;Username=postgres;Password=postgres",
    "rediscs": "devtalk-redis:6379"
  },

  "JWT": {
    "Key": "YourSuperSecretKeyAtLeast32CharactersLong",
    "Issure": "DevTalkAPI",
    "Audience": "DevTalkClient",
    "DurationInMinutes": 60
  },
  "DefaultUser": {
    "firstname": "Admin",
    "lastname": "User",
    "email": "admin@devtalk.com",
    "username": "admin",
    "password": "Admin@123456",
    "avatar": "https://ui-avatars.com/api/?name=Admin+User",
    "filename": "default-avatar.png"
  },
  "GoogleOauth": {
    "ClientId": "xxxxx",
    "ClientSecret": "xxxxx"
  }
}
